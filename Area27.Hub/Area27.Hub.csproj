<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Area27.Hub</PackageId>
    <Version>1.0.0</Version>
    <Authors>Area27</Authors>
    <Company>Area27</Company>
    <Description>Reusable utilities for validation, string handling, and basic arithmetic helpers.</Description>
    <PackageTags>utilities;validation;extensions;calculator</PackageTags>
    <RepositoryUrl>https://github.com/area27/Area27.Hub</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
</Project>
